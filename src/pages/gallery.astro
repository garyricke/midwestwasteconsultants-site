---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import CtaBand from "../components/CtaBand.astro";

// Real field photos (first batch from the team). More to come from Greg's set.
const images = [
  { src: "/images/photos/roll-off-driveway.webp", alt: "Roll-off dumpster placed on a residential driveway" },
  { src: "/images/photos/truck-logo.webp", alt: "Midwest Waste collection truck with the polar-bear logo" },
  { src: "/images/photos/branded-frontloads.webp", alt: "Front-load dumpsters branded with the Midwest Waste logo" },
  { src: "/images/photos/roll-off-containers.webp", alt: "Roll-off containers staged at a commercial cleanout" },
  { src: "/images/photos/plano-asphalt.webp", alt: "Front-load dumpsters servicing an apartment cleanout" },
  { src: "/images/photos/loader.webp", alt: "Wheel loader loaded on a lowboy trailer for transport" },
  { src: "/images/photos/forklift-1.webp", alt: "Heavy forklift loaded for transport at the yard" },
  { src: "/images/photos/forklift-2.webp", alt: "Hyster forklift staged on a trailer" },
  { src: "/images/photos/tinley-nonhaz-1.webp", alt: "Collected non-hazardous materials staged for diversion" },
  { src: "/images/photos/tinley-nonhaz-3.webp", alt: "Paint and coatings staged for non-hazardous disposal" },
];
---

<Layout
  title="Gallery"
  description="A look at Midwest Waste Consultants — our work across the Fox Valley, event waste management, and drone footage from the field."
>
  <PageHero
    eyebrow="Gallery"
    title="A look at the work."
    subtitle="Trucks, branded containers, equipment, and real jobs across the Fox Valley — with more on the way."
  />

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        images.map((img) => (
          <div class="overflow-hidden rounded-2xl border border-rule bg-steel">
            <img src={img.src} alt={img.alt} loading="lazy" class="aspect-[4/3] w-full object-cover transition-transform duration-500 hover:scale-105" />
          </div>
        ))
      }
    </div>
  </section>

  <CtaBand />
</Layout>
