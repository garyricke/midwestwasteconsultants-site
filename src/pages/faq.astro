---
import Layout from "../layouts/Layout.astro";
import CtaBand from "../components/CtaBand.astro";
import { FAQS } from "../config/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: FAQS.map((f) => ({
      "@type": "Question",
      name: f.question,
      acceptedAnswer: { "@type": "Answer", text: f.answer },
    })),
  },
];
---

<Layout
  title="FAQ"
  description="Answers to common questions about waste consulting, brokering, nationwide coordination, and recycling programs."
  schema={schema}
>
  <section class="relative isolate overflow-hidden bg-navy">
    <img
      src="https://res.cloudinary.com/dsbllwpbh/image/upload/f_auto,q_auto/mwc/images/photos/faq-hero"
      alt="Different categories of waste sorted into groups in front of a Midwest Waste roll-off dumpster"
      width="1600"
      height="900"
      fetchpriority="high"
      decoding="async"
      class="absolute inset-0 -z-10 h-full w-full object-cover object-right"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-navy-deep/95 via-navy-deep/80 to-navy-deep/30" aria-hidden="true"></div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-navy-deep/70 to-transparent" aria-hidden="true"></div>
    <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
      <span class="eyebrow border-l-2 border-orange pl-3">FAQ</span>
      <h1 class="mt-4 max-w-2xl text-4xl font-extrabold leading-[1.08] text-white sm:text-5xl">
        Frequently asked questions.
      </h1>
      <p class="mt-5 max-w-xl text-lg text-white/80">
        Straight answers about how waste consulting and brokering actually work.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-16">
    <div class="divide-y divide-rule rounded-2xl border border-rule bg-white">
      {
        FAQS.map((f, i) => (
          <details class="group px-6" open={i === 0}>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 font-display text-lg font-bold text-navy">
              {f.question}
              <svg class="h-5 w-5 flex-shrink-0 text-orange transition-transform group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
            </summary>
            <p class="pb-5 text-muted">{f.answer}</p>
          </details>
        ))
      }
    </div>

    <p class="mt-8 text-center text-muted">
      Still have a question? <a href="/contact#quote" class="font-semibold text-orange">Ask us directly →</a>
    </p>
  </section>

  <CtaBand />
</Layout>
