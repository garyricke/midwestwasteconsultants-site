---
import Layout from "../layouts/Layout.astro";
import CtaBand from "../components/CtaBand.astro";
import Stars from "../components/Stars.astro";
import { SITE, SERVICES, REVIEW_STATS } from "../config/site";

// Hand-picked snippets from the Google reviews for the homepage carousel —
// chosen for variety (residential, repeat, price vs. big haulers, commercial,
// contractor, last-minute) and brevity. Full set lives on /reviews.
const featuredReviews = [
  { body: "We rented a 15-yard dumpster for a home clean-up and couldn't be happier. Communication with Greg was fantastic, drop-off and pick-up were timely, and the price can't be beat.", author: "Erin and Travis Brown" },
  { body: "Since switching from the “big” waste hauler to Midwest for half the cost, we haven't noticed any disruption in service. Tyler and Greg are professional, with no heavy-handed sales pitch.", author: "Cindy Ybarra" },
  { body: "By far the best garbage experience I've had. We needed a large dumpster for a basement and garage cleanout, and Greg and team delivered same day at a great rate.", author: "Rachel Hyde" },
  { body: "I use Midwest Waste for my two business locations. Super responsive, very competitively priced — they beat my current supplier — and just great people to work with.", author: "Belinda Demski" },
  { body: "We're a disaster-mitigation contractor and our needs fluctuate by project. The quick response and flexibility Midwest provides is truly best-in-class service.", author: "Walter Sutphin" },
  { body: "Great experience, great company. The 30-day rental was a game changer. Highly recommended — Greg is the best!", author: "Genel Thompson" },
  { body: "Midwest Waste Consultants are THE BEST. Professional, reliable, and quick to respond to any question. Greg and Tyler really put their hearts into this business.", author: "Cheryl Kessler" },
  { body: "Excellent experience. We needed a dumpster last minute — called the day before and confirmed the morning it was needed. We got it in record time.", author: "Diana Chapa" },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    name: SITE.legalName,
    description: SITE.description,
    url: SITE.url,
    telephone: SITE.phone,
    foundingDate: SITE.established,
    areaServed: "United States",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Sugar Grove",
      addressRegion: "IL",
      addressCountry: "US",
    },
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: REVIEW_STATS.average,
      reviewCount: REVIEW_STATS.count,
    },
    sameAs: [SITE.social.facebook, SITE.social.linkedin],
  },
];
---

<Layout schema={schema}>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-navy">
    <div class="absolute inset-0">
      <img src="/images/photos/truck-logo.webp" alt="" class="h-full w-full object-cover opacity-80" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy via-navy/80 to-navy/35"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-6 py-24 sm:py-32">
      <span class="eyebrow border-l-2 border-orange pl-3">Waste Consulting · Brokering · Sustainability</span>
      <h1 class="mt-5 max-w-3xl text-4xl font-extrabold leading-[1.05] text-white sm:text-5xl lg:text-6xl">
        Stop throwing your money in the trash.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-white/80">
        Most businesses overpay for waste service and never know it — buried in
        surcharges, locked into auto-renewals, hauling half-empty containers. We
        sit on <em>your</em> side of the table. Owner-operated, 30+ years in the
        field, and a nationwide vendor network behind every recommendation.
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a href="/contact#quote" class="rounded-full bg-orange px-8 py-4 text-center font-display font-extrabold text-navy-deep transition-transform hover:-translate-y-0.5">
          Get a Free Waste Review
        </a>
        <a href={SITE.appUrl} target="_blank" rel="noopener" class="rounded-full border border-white/30 px-8 py-4 text-center font-display font-bold text-white transition-colors hover:bg-white/10">
          Need a dumpster now? →
        </a>
      </div>
      <div class="mt-10 flex items-center gap-3 text-sm text-white/70">
        <Stars rating={5} />
        <span><span class="font-bold text-white">{REVIEW_STATS.average.toFixed(1)}</span> from {REVIEW_STATS.count} Google reviews</span>
      </div>
    </div>
  </section>

  <!-- PROOF BAR -->
  <section class="border-b border-rule bg-white">
    <div class="mx-auto grid max-w-6xl grid-cols-2 gap-px overflow-hidden px-6 py-10 sm:grid-cols-4">
      {
        [
          { n: "30+", l: "Years in the field" },
          { n: "Owner", l: "Operated — talk to a person" },
          { n: "50", l: "States we can broker across" },
          { n: "4.8★", l: "From 64 Google reviews" },
        ].map((s) => (
          <div class="px-4 text-center">
            <div class="font-display text-3xl font-extrabold text-navy sm:text-4xl">{s.n}</div>
            <div class="mt-1 text-sm text-muted">{s.l}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- VALUE PROP -->
  <section class="mx-auto max-w-6xl px-6 py-20">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <span class="eyebrow">Why Midwest Waste</span>
        <h2 class="mt-3 text-3xl font-extrabold text-navy sm:text-4xl">
          The waste industry profits from confusion. We profit from clarity.
        </h2>
        <p class="mt-5 text-muted">
          National haulers count on you not reading the fine print. We've spent
          three decades on the other side of those contracts, and now we use that
          knowledge for you — finding the overcharges, killing the auto-renewals,
          and right-sizing service so you pay for what you actually throw away.
        </p>
        <ul class="mt-6 space-y-4">
          {
            [
              ["Independent & on your side", "We're brokers and consultants, not a hauler chasing a quota. Our only job is lowering your cost and hassle."],
              ["Local hands, national reach", "Our trucks run the Fox Valley; our brokering coordinates service across the country for multi-site clients."],
              ["You talk to an owner", "No call center, no runaround. The person who answers can make a decision."],
            ].map(([t, d]) => (
              <li class="flex gap-3">
                <svg class="mt-0.5 h-6 w-6 flex-shrink-0 text-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                <span><strong class="font-display text-navy">{t}.</strong> <span class="text-muted">{d}</span></span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="rounded-2xl border border-rule bg-steel p-8" data-review-carousel aria-roledescription="carousel" aria-label="Customer reviews">
        <div class="grid">
          {
            featuredReviews.map((r, i) => (
              <figure
                class="col-start-1 row-start-1 transition-opacity duration-700 ease-out"
                data-slide
                style={i === 0 ? "opacity:1" : "opacity:0;pointer-events:none"}
                aria-hidden={i === 0 ? "false" : "true"}
              >
                <blockquote class="font-display text-xl font-bold leading-snug text-navy">“{r.body}”</blockquote>
                <figcaption class="mt-5 flex flex-wrap items-center gap-3">
                  <Stars rating={5} />
                  <span class="text-sm font-semibold text-navy">{r.author}</span>
                  <span class="text-sm text-muted">· Google</span>
                </figcaption>
              </figure>
            ))
          }
        </div>
        <div class="mt-6 flex items-center justify-between">
          <div class="flex items-center gap-2" data-dots>
            {
              featuredReviews.map((_, i) => (
                <button
                  type="button"
                  data-dot
                  aria-label={`Show review ${i + 1}`}
                  class="h-2 rounded-full transition-all duration-300"
                  style={i === 0 ? "width:1.25rem;background:#FF8200" : "width:0.5rem;background:rgba(20,40,73,0.2)"}
                ></button>
              ))
            }
          </div>
          <a href="/reviews" class="font-display text-sm font-bold text-orange hover:underline">Read all reviews →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="bg-steel">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <div class="max-w-2xl">
        <span class="eyebrow">What We Do</span>
        <h2 class="mt-3 text-3xl font-extrabold text-navy sm:text-4xl">From a single dumpster to a 500-location program.</h2>
        <p class="mt-4 text-muted">Strategy and brokering up top; the hands-on services that built our reputation right alongside.</p>
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          SERVICES.map((s) => (
            <a href={s.appCta ? SITE.appUrl : `/services/${s.slug}`} target={s.appCta ? "_blank" : undefined} rel={s.appCta ? "noopener" : undefined} class="group flex flex-col rounded-2xl border border-rule bg-white p-7 transition-all hover:-translate-y-1 hover:border-orange hover:shadow-lg">
              <h3 class="font-display text-lg font-bold text-navy group-hover:text-orange">{s.title}</h3>
              <p class="mt-2 flex-1 text-sm text-muted">{s.summary}</p>
              <span class="mt-4 font-display text-sm font-bold text-orange">
                {s.appCta ? "Order on midwestwaste.app ↗" : "Learn more →"}
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- TWO PATHS -->
  <section class="mx-auto max-w-6xl px-6 py-20">
    <div class="max-w-2xl">
      <span class="eyebrow">Two Ways to Work With Us</span>
      <h2 class="mt-3 text-3xl font-extrabold text-navy sm:text-4xl">One company. Two front doors.</h2>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      <div class="rounded-2xl border-2 border-navy bg-navy p-8 text-white">
        <span class="eyebrow text-orange">This site</span>
        <h3 class="mt-2 text-2xl font-extrabold">The Boardroom</h3>
        <p class="mt-3 text-white/80">Consulting, contract brokering, sustainability programs, and multi-location strategy. Best when the question is bigger than one pickup.</p>
        <a href="/services" class="mt-6 inline-block rounded-full bg-orange px-6 py-3 font-display font-extrabold text-navy-deep transition-transform hover:-translate-y-0.5">Explore consulting</a>
      </div>
      <div class="rounded-2xl border-2 border-rule bg-white p-8">
        <span class="eyebrow">midwestwaste.app</span>
        <h3 class="mt-2 text-2xl font-extrabold text-navy">The Driveway</h3>
        <p class="mt-3 text-muted">Need a roll-off dumpster this week? Pick a size, pay online, and we route it to the closest qualified hauler. Fast, transactional, no phone tag.</p>
        <a href={SITE.appUrl} target="_blank" rel="noopener" class="mt-6 inline-block rounded-full border border-navy px-6 py-3 font-display font-bold text-navy transition-colors hover:bg-navy hover:text-white">Order a dumpster ↗</a>
      </div>
    </div>
  </section>

  <!-- CREDIBILITY / CASE -->
  <section class="bg-navy-deep">
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-6 py-20 lg:grid-cols-2">
      <div>
        <span class="eyebrow text-orange">Proven on the big stage</span>
        <h2 class="mt-3 text-3xl font-extrabold text-white sm:text-4xl">We managed the waste &amp; recycling for LIV Golf at Rich Harvest Farms.</h2>
        <p class="mt-4 text-white/75">
          Major events are waste management on hard mode — high volume, tight
          windows, zero room for error, and a brand watching. We planned the
          containers, integrated recycling, and coordinated cleanup. <span class="text-white/50">[Placeholder — expand with results, tonnage, and photos.]</span>
        </p>
        <a href="/services/event-waste-management" class="mt-6 inline-block font-display font-bold text-orange hover:underline">See event services →</a>
      </div>
      <div class="overflow-hidden rounded-2xl border border-white/10">
        <img src="/images/photos/liv-golf.webp" alt="Championship golf tournament — waste and recycling managed on site" class="h-full w-full object-cover" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- RESOURCES TEASER -->
  <section class="mx-auto max-w-6xl px-6 py-20">
    <div class="flex flex-col items-start justify-between gap-6 rounded-2xl bg-steel p-10 md:flex-row md:items-center">
      <div class="max-w-2xl">
        <span class="eyebrow">Resources & The Podcast</span>
        <h2 class="mt-3 text-2xl font-extrabold text-navy sm:text-3xl">Learn how the waste game really works.</h2>
        <p class="mt-3 text-muted">Plain-spoken breakdowns of contract traps, diversion wins, and stories from the route — including our upcoming podcast. <span class="text-muted/70">[Podcast launching soon.]</span></p>
      </div>
      <a href="/resources" class="rounded-full bg-navy px-7 py-3.5 font-display font-extrabold text-white transition-transform hover:-translate-y-0.5">Browse resources</a>
    </div>
  </section>

  <CtaBand />

  <script>
    // Auto-rotating review carousel: fades between slides, pauses on hover/focus,
    // honors reduced-motion, and lets the dots jump directly to a review.
    const carousel = document.querySelector("[data-review-carousel]");
    if (carousel) {
      const slides = Array.from(carousel.querySelectorAll("[data-slide]"));
      const dots = Array.from(carousel.querySelectorAll("[data-dot]"));
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      let idx = 0;
      let timer;

      const show = (n) => {
        idx = (n + slides.length) % slides.length;
        slides.forEach((s, i) => {
          const active = i === idx;
          s.style.opacity = active ? "1" : "0";
          s.style.pointerEvents = active ? "" : "none";
          s.setAttribute("aria-hidden", active ? "false" : "true");
        });
        dots.forEach((d, i) => {
          const active = i === idx;
          d.style.width = active ? "1.25rem" : "0.5rem";
          d.style.background = active ? "#FF8200" : "rgba(20,40,73,0.2)";
        });
      };

      const start = () => {
        stop();
        if (!reduce && slides.length > 1) timer = window.setInterval(() => show(idx + 1), 6000);
      };
      const stop = () => timer && window.clearInterval(timer);

      dots.forEach((d, i) =>
        d.addEventListener("click", () => {
          show(i);
          start();
        })
      );
      carousel.addEventListener("mouseenter", stop);
      carousel.addEventListener("mouseleave", start);
      carousel.addEventListener("focusin", stop);
      carousel.addEventListener("focusout", start);

      show(0);
      start();
    }
  </script>
</Layout>
