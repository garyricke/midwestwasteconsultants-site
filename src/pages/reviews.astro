---
import Layout from "../layouts/Layout.astro";
import CtaBand from "../components/CtaBand.astro";
import Stars from "../components/Stars.astro";
import { SITE, REVIEWS, REVIEW_STATS } from "../config/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    name: SITE.legalName,
    url: SITE.url,
    telephone: SITE.phone,
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: REVIEW_STATS.average,
      reviewCount: REVIEW_STATS.count,
    },
    review: REVIEWS.map((r) => ({
      "@type": "Review",
      author: { "@type": "Person", name: r.author },
      reviewRating: { "@type": "Rating", ratingValue: r.rating, bestRating: 5 },
      reviewBody: r.body,
    })),
  },
];
---

<Layout
  title="Reviews"
  description="What our customers say about Midwest Waste Consultants — 4.8 stars across 64 Google reviews."
  schema={schema}
>
  <section class="relative isolate overflow-hidden bg-navy">
    <img
      src="/images/photos/reviews-hero.webp"
      alt="A happy homeowner smiling in front of a Midwest Waste roll-off dumpster during a driveway cleanout"
      width="1600"
      height="900"
      fetchpriority="high"
      decoding="async"
      class="absolute inset-0 -z-10 h-full w-full object-cover object-right"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-navy-deep/95 via-navy-deep/80 to-navy-deep/30" aria-hidden="true"></div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-navy-deep/70 to-transparent" aria-hidden="true"></div>
    <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
      <span class="eyebrow border-l-2 border-orange pl-3">Reviews</span>
      <h1 class="mt-4 max-w-2xl text-4xl font-extrabold leading-[1.08] text-white sm:text-5xl">
        What our customers have to say.
      </h1>
      <p class="mt-5 max-w-xl text-lg text-white/80">
        {REVIEW_STATS.average.toFixed(1)} stars across {REVIEW_STATS.count} verified Google reviews — from homeowners and businesses across the Fox Valley.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="flex flex-col items-center gap-3 text-center">
      <Stars rating={5} class="scale-125" />
      <p class="font-display text-2xl font-extrabold text-navy">
        {REVIEW_STATS.average.toFixed(1)} out of 5
      </p>
      <p class="text-muted">Based on {REVIEW_STATS.count} verified Google reviews</p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {
        REVIEWS.map((r) => (
          <figure class="flex flex-col rounded-2xl border border-rule bg-white p-7">
            <Stars rating={r.rating} />
            <blockquote class="mt-4 flex-1 text-ink">{r.body}</blockquote>
            <figcaption class="mt-5 border-t border-rule pt-4">
              <span class="font-display font-bold text-navy">{r.author}</span>
              <span class="text-sm text-muted"> · {r.date} · Google</span>
              {r.ownerReply && (
                <p class="mt-3 rounded-lg bg-steel p-3 text-sm text-muted">
                  <span class="font-display font-semibold text-navy">Owner reply:</span> {r.ownerReply}
                </p>
              )}
            </figcaption>
          </figure>
        ))
      }
    </div>

    <p class="mt-8 text-center text-sm text-muted">
      Read more on our
      <a href={SITE.social.facebook} target="_blank" rel="noopener" class="font-semibold text-orange">Facebook page</a>.
    </p>
  </section>

  <CtaBand heading="Join the customers who stopped overpaying." />
</Layout>
