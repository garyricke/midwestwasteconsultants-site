---
import Layout from "../layouts/Layout.astro";
import CtaBand from "../components/CtaBand.astro";

// Placeholder article topics — replace with real posts as the blog fills in.
const articles = [
  { title: "The Criminal Nature of Auto-Renewal Clauses", tag: "Contracts", blurb: "How a single paragraph locks you into rising rates for years — and how to get out." },
  { title: "Why Your Dumpster Is the Wrong Size", tag: "Cost", blurb: "Right-sizing service is the fastest way to stop paying to haul air." },
  { title: "What We Found in a LIV Golf Waste Stream", tag: "Events", blurb: "Lessons from managing recycling and waste at a tournament-scale event." },
  { title: "Recycling That Actually Saves Money", tag: "Sustainability", blurb: "Diversion done right shrinks the most expensive line on your bill." },
];
---

<Layout
  title="Resources & Podcast"
  description="Plain-spoken breakdowns of how the waste industry really works — contract traps, diversion wins, and stories from the route. Podcast coming soon."
>
  <section class="relative isolate overflow-hidden bg-navy">
    <img
      src="/images/photos/resources-hero.webp"
      alt="Midwest Waste owners recording a podcast in the cab of a garbage truck"
      width="1600"
      height="900"
      fetchpriority="high"
      decoding="async"
      class="absolute inset-0 -z-10 h-full w-full object-cover object-right"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-navy-deep/95 via-navy-deep/80 to-navy-deep/30" aria-hidden="true"></div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-navy-deep/70 to-transparent" aria-hidden="true"></div>
    <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
      <span class="eyebrow border-l-2 border-orange pl-3">Resources &amp; Podcast</span>
      <h1 class="mt-4 max-w-2xl text-4xl font-extrabold leading-[1.08] text-white sm:text-5xl">
        How the waste game really works.
      </h1>
      <p class="mt-5 max-w-xl text-lg text-white/80">
        No jargon. Just what three decades in the field taught us — so you can spot the traps before they cost you.
      </p>
    </div>
  </section>

  <!-- PODCAST -->
  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid items-center gap-10 rounded-2xl border border-rule bg-steel p-8 md:grid-cols-[280px_1fr] md:p-10">
      <div class="overflow-hidden rounded-xl border border-rule">
        <img src="/images/marketing/trash-talk-cover.png" alt="Podcast cover art" class="aspect-square w-full object-cover" />
      </div>
      <div>
        <span class="inline-block rounded-full bg-orange/15 px-3 py-1 font-display text-xs font-bold uppercase tracking-wide text-orange">Coming Soon</span>
        <h2 class="mt-3 text-3xl font-extrabold text-navy">The Podcast</h2>
        <p class="mt-3 text-muted">
          Two guys who know this industry cold — talking the street-fight reality
          of local hauling and the boardroom complexity of national consulting.
          The wildest things found in a dumpster, and the contract clauses that
          quietly drain your budget. <span class="text-muted/70">[Placeholder — confirm show name, hosts, and feed/host URL.]</span>
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <span class="rounded-full border border-rule bg-white px-5 py-2.5 font-display text-sm font-bold text-muted">Episodes coming soon</span>
          <a href="/contact#quote" class="rounded-full bg-navy px-5 py-2.5 font-display text-sm font-extrabold text-white transition-transform hover:-translate-y-0.5">Get notified</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ARTICLES -->
  <section class="mx-auto max-w-6xl px-6 pb-16">
    <h2 class="text-2xl font-extrabold text-navy">From the blog</h2>
    <p class="mt-2 text-muted">Coming soon — pulled from the podcast and the field. <span class="text-muted/70">[Placeholder topics below.]</span></p>
    <div class="mt-8 grid gap-6 sm:grid-cols-2">
      {
        articles.map((a) => (
          <article class="flex flex-col rounded-2xl border border-rule bg-white p-7 opacity-90">
            <span class="font-display text-xs font-bold uppercase tracking-wide text-orange">{a.tag}</span>
            <h3 class="mt-2 font-display text-xl font-bold text-navy">{a.title}</h3>
            <p class="mt-2 flex-1 text-sm text-muted">{a.blurb}</p>
            <span class="mt-4 font-display text-sm font-bold text-muted">Coming soon</span>
          </article>
        ))
      }
    </div>
  </section>

  <CtaBand />
</Layout>
