---
import Layout from "../../layouts/Layout.astro";
import CtaBand from "../../components/CtaBand.astro";
import { SITE, SERVICES } from "../../config/site";
import { SERVICE_DETAILS } from "../../data/serviceDetails";

export function getStaticPaths() {
  return SERVICES.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
const detail = SERVICE_DETAILS[service.slug];
const others = SERVICES.filter((s) => s.slug !== service.slug).slice(0, 3);

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: service.title,
    description: detail.lede,
    provider: { "@type": "LocalBusiness", name: SITE.legalName, telephone: SITE.phone },
    areaServed: "United States",
    url: new URL(`/services/${service.slug}`, SITE.url).href,
  },
];
---

<Layout title={service.title} description={detail.lede} schema={schema}>
  <!-- HERO -->
  <section class="bg-navy">
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-6 py-16 sm:py-20 lg:grid-cols-[1.3fr_1fr]">
      <div>
        <nav class="mb-5 text-sm text-white/55" aria-label="Breadcrumb">
          <a href="/services" class="hover:text-orange">Services</a>
          <span class="px-1.5">/</span>
          <span class="text-white/80">{service.title}</span>
        </nav>
        <h1 class="max-w-3xl text-4xl font-extrabold leading-[1.08] text-white sm:text-5xl">{service.title}</h1>
        <p class="mt-5 max-w-2xl text-lg text-white/75">{detail.lede}</p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          {
            service.appCta ? (
              <>
                <a href={SITE.appUrl} target="_blank" rel="noopener" class="rounded-full bg-orange px-7 py-3.5 text-center font-display font-extrabold text-navy-deep transition-transform hover:-translate-y-0.5">
                  Order at midwestwaste.app ↗
                </a>
                <a href="/contact#quote" class="rounded-full border border-white/30 px-7 py-3.5 text-center font-display font-bold text-white transition-colors hover:bg-white/10">
                  Talk to us first
                </a>
              </>
            ) : (
              <a href="/contact#quote" class="rounded-full bg-orange px-7 py-3.5 text-center font-display font-extrabold text-navy-deep transition-transform hover:-translate-y-0.5">
                Get a free quote
              </a>
            )
          }
        </div>
      </div>
      {service.image && (
        <div class="overflow-hidden rounded-2xl border border-white/10 shadow-2xl">
          <img src={service.image} alt={service.title} class="aspect-[4/3] w-full object-cover" loading="lazy" />
        </div>
      )}
    </div>
  </section>

  <!-- BODY -->
  <section class="mx-auto grid max-w-6xl gap-12 px-6 py-16 lg:grid-cols-[1.4fr_1fr]">
    <div class="prose-mwc">
      {detail.intro.map((p) => <p class="text-muted">{p}</p>)}

      <h2 class="mt-8 text-2xl font-extrabold text-navy">What's included</h2>
      <div class="mt-5 grid gap-4 sm:grid-cols-2">
        {
          detail.highlights.map((h) => (
            <div class="rounded-xl border border-rule bg-white p-5">
              <h3 class="font-display text-base font-bold text-navy">{h.title}</h3>
              <p class="mt-1.5 text-sm text-muted">{h.text}</p>
            </div>
          ))
        }
      </div>

      {detail.outro && <p class="mt-8 font-display text-lg font-semibold text-navy">{detail.outro}</p>}
    </div>

    <!-- SIDEBAR -->
    <aside class="space-y-6 lg:sticky lg:top-28 lg:self-start">
      <div class="rounded-2xl border-2 border-navy bg-navy p-6 text-white">
        <h3 class="font-display text-lg font-bold">Ready to talk?</h3>
        <p class="mt-2 text-sm text-white/80">Free, no-obligation estimate from an owner.</p>
        <a href="/contact#quote" class="mt-4 block rounded-full bg-orange px-5 py-3 text-center font-display font-extrabold text-navy-deep transition-transform hover:-translate-y-0.5">Get a quote</a>
        <a href={SITE.phoneHref} class="mt-2 block text-center font-display font-bold text-orange">{SITE.phone}</a>
      </div>
      <div class="rounded-2xl border border-rule bg-steel p-6">
        <h3 class="font-display text-sm font-bold uppercase tracking-wide text-muted">Other services</h3>
        <ul class="mt-3 space-y-2">
          {others.map((o) => (
            <li><a href={`/services/${o.slug}`} class="font-display text-sm font-semibold text-navy hover:text-orange">{o.title} →</a></li>
          ))}
        </ul>
      </div>
    </aside>
  </section>

  <CtaBand />
</Layout>
