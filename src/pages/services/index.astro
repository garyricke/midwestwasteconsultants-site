---
import Layout from "../../layouts/Layout.astro";
import CtaBand from "../../components/CtaBand.astro";
import { SITE, SERVICES } from "../../config/site";
---

<Layout
  title="Services"
  description="Waste consulting, brokering, sustainability, recycling, commercial disposal, event waste, and roll-off dumpsters — strategy and hands-on service from one owner-operated team."
>
  <section class="relative isolate overflow-hidden bg-navy">
    <img
      src="/images/photos/services-hero.webp"
      alt="Midwest Waste Consultants owners with a branded front-load collection truck"
      width="1600"
      height="900"
      fetchpriority="high"
      decoding="async"
      class="absolute inset-0 -z-10 h-full w-full object-cover object-right"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-navy-deep/95 via-navy-deep/80 to-navy-deep/30" aria-hidden="true"></div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-navy-deep/70 to-transparent" aria-hidden="true"></div>
    <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
      <span class="eyebrow border-l-2 border-orange pl-3">Services</span>
      <h1 class="mt-4 max-w-2xl text-4xl font-extrabold leading-[1.08] text-white sm:text-5xl">
        From the boardroom to the driveway.
      </h1>
      <p class="mt-5 max-w-xl text-lg text-white/80">
        Strategy, brokering, and sustainability for the long game — and the hands-on hauling services that built our reputation.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-6 md:grid-cols-2">
      {
        SERVICES.map((s) => (
          <div class="flex flex-col overflow-hidden rounded-2xl border border-rule bg-white transition-all hover:border-orange hover:shadow-lg">
            {s.image && (
              <a href={`/services/${s.slug}`} class="block overflow-hidden">
                <img src={s.image} alt={s.title} loading="lazy" class="aspect-[16/9] w-full object-cover transition-transform duration-500 hover:scale-105" />
              </a>
            )}
            <div class="flex flex-1 flex-col p-8">
            <h2 class="font-display text-xl font-bold text-navy">{s.title}</h2>
            <p class="mt-3 flex-1 text-muted">{s.summary}</p>
            <div class="mt-5 flex flex-wrap gap-3">
              <a href={`/services/${s.slug}`} class="rounded-full border border-navy px-5 py-2.5 font-display text-sm font-bold text-navy transition-colors hover:bg-navy hover:text-white">
                Learn more
              </a>
              {s.appCta && (
                <a href={SITE.appUrl} target="_blank" rel="noopener" class="rounded-full bg-orange px-5 py-2.5 font-display text-sm font-extrabold text-navy-deep transition-transform hover:-translate-y-0.5">
                  Order online ↗
                </a>
              )}
            </div>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <CtaBand />
</Layout>
