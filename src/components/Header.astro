---
import { SITE, NAV, SERVICES } from "../config/site";
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header id="site-header" class="sticky top-0 z-40 border-b border-rule">
  <!-- Utility bar (white) -->
  <div class="hidden border-b border-rule bg-white md:block">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-1.5 text-xs">
      <span class="font-display tracking-wide text-navy/70">
        {SITE.baseCity} · Serving clients nationwide
      </span>
      <div class="flex items-center gap-5">
        {
          SITE.badges.map((b) => (
            <span class="font-display text-[0.7rem] uppercase tracking-[0.14em] text-muted">
              {b}
            </span>
          ))
        }
        <a href={SITE.phoneHref} class="flex items-center gap-1.5 font-display font-bold text-navy">
          <svg class="h-4 w-4 text-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {SITE.phone}
        </a>
      </div>
    </div>
  </div>

  <!-- Main nav (brand blue — matches the logo's baked-in blue #1D427B) -->
  <div class="bg-[#1D427B]">
    <div class="navbar-inner mx-auto flex max-w-6xl items-center justify-between gap-4 px-6">
    <a href="/" class="logo-link flex items-center" aria-label={`${SITE.name} home`}>
      <img src="/images/logo-full-white-on-blue.svg" alt={SITE.name} class="logo-full w-auto" width="874" height="867" />
      <img src="/images/logo-mw-white-on-blue.svg" alt="" aria-hidden="true" class="logo-mw w-auto" width="874" height="867" />
    </a>

    <nav class="hidden items-center gap-6 lg:flex" aria-label="Primary">
      {
        NAV.map((item) =>
          item.label === "Services" ? (
            <div class="group relative">
              <a
                href={item.href}
                class:list={[
                  "flex items-center gap-1 font-display text-sm font-semibold transition-colors hover:text-orange",
                  isActive(item.href) ? "text-orange" : "text-white",
                ]}
              >
                {item.label}
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
              </a>
              <div class="invisible absolute left-1/2 top-full z-50 w-64 -translate-x-1/2 pt-3 opacity-0 transition-all group-hover:visible group-hover:opacity-100">
                <ul class="rounded-xl border border-rule bg-white p-2 shadow-xl">
                  {SERVICES.map((s) => (
                    <li>
                      <a href={`/services/${s.slug}`} class="block rounded-lg px-3 py-2 text-sm text-ink transition-colors hover:bg-steel hover:text-navy">
                        {s.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                "font-display text-sm font-semibold transition-colors hover:text-orange",
                isActive(item.href) ? "text-orange" : "text-white",
              ]}
            >
              {item.label}
            </a>
          )
        )
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="/contact#quote"
        class="hidden rounded-full bg-orange px-5 py-2.5 font-display text-sm font-extrabold text-navy-deep transition-transform hover:-translate-y-0.5 sm:inline-block"
      >
        Get a Quote
      </a>
      <!-- Mobile toggle -->
      <button
        id="nav-toggle"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-white lg:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
    </div>
  </div>

  <!-- Mobile nav panel -->
  <nav
    id="mobile-nav"
    class="hidden border-t border-rule bg-white px-6 py-4 lg:hidden"
    aria-label="Mobile"
  >
    <ul class="flex flex-col gap-1">
      {
        NAV.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                "block rounded-lg px-3 py-2.5 font-display font-semibold",
                isActive(item.href) ? "bg-steel text-orange" : "text-navy",
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li class="mt-2">
        <a href="/contact#quote" class="block rounded-full bg-orange px-5 py-3 text-center font-display font-extrabold text-navy-deep">
          Get a Quote
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const panel = document.getElementById("mobile-nav");
  toggle?.addEventListener("click", () => {
    const open = panel?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });

  // Shrink the nav + swap the full logo for the compact "MW" mark on scroll.
  const header = document.getElementById("site-header");
  const onScroll = () => {
    if (!header) return;
    header.classList.toggle("is-scrolled", window.scrollY > 24);
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>

<style>
  /* Logo scales down and swaps on scroll. Full (with text) on load; MW when small. */
  .navbar-inner { padding-block: 0.9rem; transition: padding-block 0.25s ease; }
  .logo-full { height: 5.5rem; transition: height 0.25s ease; }
  .logo-mw { display: none; height: 2.75rem; transition: height 0.25s ease; }

  #site-header.is-scrolled .navbar-inner { padding-block: 0.4rem; }
  #site-header.is-scrolled .logo-full { display: none; }
  #site-header.is-scrolled .logo-mw { display: block; }

  @media (max-width: 767px) {
    .logo-full { height: 4rem; }
  }
</style>
