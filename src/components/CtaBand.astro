---
import { SITE } from "../config/site";
interface Props {
  heading?: string;
  text?: string;
}
const {
  heading = "Stop throwing your money in the trash.",
  text = "Get a free, no-obligation review of your waste spend from an owner who's been doing this for 30 years.",
} = Astro.props;
---

<section class="bg-navy">
  <div class="mx-auto max-w-6xl px-6 py-16 text-center">
    <span class="eyebrow text-orange">Free Estimate</span>
    <h2 class="mx-auto mt-3 max-w-3xl text-3xl font-extrabold text-white sm:text-4xl">
      {heading}
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-white/75">{text}</p>
    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="/contact#quote" class="rounded-full bg-orange px-7 py-3.5 font-display font-extrabold text-navy-deep transition-transform hover:-translate-y-0.5">
        Get a Free Quote
      </a>
      <a href={SITE.phoneHref} class="rounded-full border border-white/25 px-7 py-3.5 font-display font-bold text-white transition-colors hover:bg-white/10">
        Call {SITE.phone}
      </a>
    </div>
  </div>
</section>
